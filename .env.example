# ============================================
# AI Intelligence System — Environment Variables
# ============================================
# Copy this to .env and fill in your values.
# Never commit .env to git!

# PRIMARY (FREE): Groq API key for Llama 3.3 70B scoring & insights
# Get free key: https://console.groq.com/keys (30 RPM, 1000 RPD — plenty!)
GROQ_API_KEY=gsk_...

# OPTIONAL (PAID): Anthropic API key — only if you want Claude as fallback
# ANTHROPIC_API_KEY=sk-ant-api03-...

# Required: Telegram Bot token (create via @BotFather)
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# Required: Your Telegram chat ID (find via @userinfobot)
TELEGRAM_CHAT_ID=123456789

# Optional: Reddit API credentials (for higher rate limits)
# Without these, uses public JSON endpoint (lower limits)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# Optional: Product Hunt API token (for PH data)
PRODUCTHUNT_API_TOKEN=

# Optional: Twitter/X API Bearer token (for tweet tracking)
# Get from https://developer.twitter.com/en/portal
TWITTER_BEARER_TOKEN=

# Optional: YouTube Data API v3 key (for video tracking)
# Get from https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=
